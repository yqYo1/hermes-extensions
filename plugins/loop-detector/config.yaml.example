plugins:
  loop_detector:
    enabled: true
    tool_loop:
      enabled: true
      consecutive_threshold: 3
      window_size: 10
      window_threshold: 4
      alternating_enabled: true
      alternating_min_length: 6
    response_loop:
      enabled: true
      similarity_threshold: 0.95
      window_size: 10
      min_repetitions: 3
    confirmation:
      enabled: true
      on_error: block
      timeout: 30
    response:
      max_blocks_per_session: 5
      recovery_notice: ""
